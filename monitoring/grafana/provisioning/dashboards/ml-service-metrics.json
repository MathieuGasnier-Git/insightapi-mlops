{
  "title": "InsightAPI - ml-service metrics",
  "uid": "insightapi-ml-service",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["insightapi", "ml-service"],
  "panels": [
    {
      "id": 1,
      "title": "Prediction request volume",
      "description": "Rate of POST /predict requests received (ml_service_prediction_requests_total)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_service_prediction_requests_total[5m])",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Prediction request latency",
      "description": "p50/p95 latency of /predict requests (ml_service_prediction_request_latency_seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(ml_service_prediction_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(ml_service_prediction_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate",
      "description": "Share of /predict requests that failed (ml_service_prediction_requests_failed_total / ml_service_prediction_requests_total)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_service_prediction_requests_failed_total[5m]) / rate(ml_service_prediction_requests_total[5m])",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Health status",
      "description": "Reachability (Prometheus scrape, up{job=\"ml-service\"}) vs. app-reported health (ml_service_health_status: 1 = model loaded)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"ml-service\"}",
          "legendFormat": "scrape reachable"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_service_health_status",
          "legendFormat": "model loaded"
        }
      ]
    }
  ]
}
