DATABASE_URL=postgres://user:password@localhost:5432/insightapi
PORT=3000

# Shared secret for verifying frontend-issued JWTs
JWT_SECRET=replace-with-a-strong-secret

# Shared secret proving a /api/auth/exchange call came from the frontend's
# own server (which already validated the user via NextAuth), not an
# arbitrary client claiming an identity
INTERNAL_EXCHANGE_SECRET=replace-with-a-strong-secret

# Origin allowed to call this gateway from the browser (CORS)
FRONTEND_URL=http://localhost:3000

# Downstream services proxied behind this gateway
ML_SERVICE_URL=http://localhost:8000
SERVICE_2_URL=http://localhost:4002
